# ── Core ─────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-generate-with-python-secrets-token-hex-32
JWT_SECRET_KEY=change-me-generate-with-python-secrets-token-hex-32
FLASK_ENV=production
APP_NAME=WorkPro
FRONTEND_URL=https://yourdomain.com

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/workpro

# ── Email (Brevo REST API) ────────────────────────────────────────────────────
# Get from Brevo: Settings → SMTP & API → API Keys tab (NOT the SMTP tab)
BREVO_API_KEY=xkeysib-...
MAIL_DEFAULT_SENDER=WorkPro <hello@yourdomain.com>

# ── AI (Groq) ─────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...

# ── M-Pesa / Daraja ───────────────────────────────────────────────────────────
MPESA_CONSUMER_KEY=your-consumer-key
MPESA_CONSUMER_SECRET=your-consumer-secret
MPESA_PASSKEY=your-passkey
MPESA_SHORTCODE=174379
MPESA_ENV=sandbox                           # sandbox | production
MPESA_CALLBACK_URL=https://yourdomain.com/subscription/mpesa-callback

# M-Pesa B2C (for auto commission payouts to referrers)
MPESA_INITIATOR_NAME=testapi
MPESA_SECURITY_CREDENTIAL=your-b2c-security-credential

# ── Pricing ───────────────────────────────────────────────────────────────────
PRO_MONTHLY_PRICE=999
PRO_ANNUAL_PRICE=8999

# ── Referral / Commission ─────────────────────────────────────────────────────
COMMISSION_RATE=20          # % of payment sent to referrer (overridable in admin panel)

# ── Support ───────────────────────────────────────────────────────────────────
WHATSAPP_SUPPORT=254712345678   # International format, no + (overridable in admin panel)
